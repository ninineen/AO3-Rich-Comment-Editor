{
  "name": "ao3-rich-comment-editor",
  "version": "1.0.0",
  "description": "Format AO3 comments with rich text editing",
  "private": true,
  "scripts": {
    "start": "npm install && npm run vendor && npm run lint && npm run build",
    "vendor": "cp node_modules/squire-rte/dist/squire-raw.js vendor/squire.js && patch vendor/squire.js vendor/squire-no-innerhtml.patch",
    "lint": "web-ext lint",
    "build": "web-ext build --overwrite-dest",
    "run:firefox": "web-ext run --target firefox-desktop --verbose --start-url https://archiveofourown.org/works/86984576/chapters/230309206#workskin",
    "test": "jest"
  },
  "dependencies": {
    "squire-rte": "2.3.2"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.0",
    "web-ext": "^10.0.0"
  }
}
